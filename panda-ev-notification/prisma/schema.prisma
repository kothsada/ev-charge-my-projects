// ============================================================
// Panda EV Hub Platform — Notification Microservice
// Database: panda-ev-core-instance-db-a1
// ============================================================

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  schemas  = ["panda_ev_noti"]
}

// ============================================================
// ENUMS
// ============================================================

enum NotificationChannel {
  FCM
  WEBSOCKET
  BOTH

  @@schema("panda_ev_noti")
}

enum NotificationStatus {
  PENDING
  SENT
  DELIVERED
  READ
  CLICKED
  FAILED
  SUPPRESSED

  @@schema("panda_ev_noti")
}

enum NotificationPriority {
  HIGH
  NORMAL
  LOW

  @@schema("panda_ev_noti")
}

// ============================================================
// NOTIFICATION TEMPLATES
// ============================================================

/// Reusable notification templates with i18n title/body per language
model NotificationTemplate {
  id            String               @id @default(uuid()) @db.Uuid
  slug          String               @unique @db.VarChar(100)
  channel       NotificationChannel
  priority      NotificationPriority @default(NORMAL)
  titleLo       String               @map("title_lo") @db.VarChar(255)
  titleEn       String               @map("title_en") @db.VarChar(255)
  titleZh       String               @map("title_zh") @db.VarChar(255)
  bodyLo        String               @map("body_lo") @db.Text
  bodyEn        String               @map("body_en") @db.Text
  bodyZh        String               @map("body_zh") @db.Text
  imageUrl      String?              @map("image_url") @db.VarChar(1000)
  deepLinkPath  String?              @map("deep_link_path") @db.VarChar(500)
  actionButtons Json?                @map("action_buttons")
  isActive      Boolean              @default(true) @map("is_active")
  createdAt     DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime             @updatedAt @map("updated_at") @db.Timestamptz(6)

  logs NotificationLog[]

  @@map("notification_templates")
  @@schema("panda_ev_noti")
}

// ============================================================
// NOTIFICATION LOGS
// ============================================================

/// Delivery record for every push notification sent through the pipeline
model NotificationLog {
  id              String               @id @default(uuid()) @db.Uuid
  templateId      String?              @map("template_id") @db.Uuid
  userId          String               @db.VarChar(150)
  sessionId       String?              @map("session_id") @db.VarChar(150)
  chargerIdentity String?              @map("charger_identity") @db.VarChar(100)
  stationId       String?              @map("station_id") @db.VarChar(150)
  channel         NotificationChannel
  type            String               @db.VarChar(100)
  priority        NotificationPriority @default(NORMAL)
  title           String               @db.VarChar(255)
  body            String               @db.VarChar(1000)
  payload         Json?
  status          NotificationStatus   @default(PENDING)
  fcmMessageId    String?              @map("fcm_message_id") @db.VarChar(500)
  errorMessage    String?              @map("error_message") @db.Text
  retryCount      Int                  @default(0) @map("retry_count")
  sentAt          DateTime             @default(now()) @map("sent_at") @db.Timestamptz(6)
  deliveredAt     DateTime?            @map("delivered_at") @db.Timestamptz(6)
  readAt          DateTime?            @map("read_at") @db.Timestamptz(6)
  clickedAt       DateTime?            @map("clicked_at") @db.Timestamptz(6)

  template NotificationTemplate? @relation(fields: [templateId], references: [id])

  @@unique([sessionId, type])
  @@index([userId, sentAt])
  @@index([stationId, sentAt])
  @@index([status, sentAt])
  @@index([chargerIdentity, sentAt])
  @@map("notification_logs")
  @@schema("panda_ev_noti")
}

// ============================================================
// FCM DEVICE REGISTRY
// ============================================================

/// Canonical FCM token store — one row per device, owned by Notification Service.
/// Tokens are upserted on device.registered events and soft-deleted on stale responses.
model UserFcmDevice {
  id          String    @id @default(uuid()) @db.Uuid
  userId      String    @map("user_id") @db.VarChar(150)
  fcmToken    String    @unique @map("fcm_token") @db.VarChar(500)
  platform    String?   @db.VarChar(20)
  appVersion  String?   @map("app_version") @db.VarChar(30)
  isActive    Boolean   @default(true) @map("is_active")
  lastUsedAt  DateTime? @map("last_used_at") @db.Timestamptz(6)
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([userId, isActive])
  @@index([lastUsedAt])
  @@map("user_fcm_devices")
  @@schema("panda_ev_noti")
}

// ============================================================
// USER PREFERENCES
// ============================================================

/// Per-user notification opt-in settings and language preference.
/// FCM tokens are stored separately in UserFcmDevice.
model UserNotificationPreference {
  id              String   @id @default(uuid()) @db.Uuid
  userId          String   @unique @map("user_id") @db.VarChar(150)
  language        String   @default("lo") @db.VarChar(10)
  batteryAlerts   Boolean  @default(true) @map("battery_alerts")
  sessionAlerts   Boolean  @default(true) @map("session_alerts")
  overstayAlerts  Boolean  @default(true) @map("overstay_alerts")
  promoAlerts     Boolean  @default(false) @map("promo_alerts")
  quietHoursStart Int?     @map("quiet_hours_start") @db.Integer
  quietHoursEnd   Int?     @map("quiet_hours_end") @db.Integer
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("user_notification_preferences")
  @@schema("panda_ev_noti")
}

// ============================================================
// AGGREGATED STATISTICS
// ============================================================

/// Pre-aggregated per-station session and revenue metrics, bucketed by hour
model StationHourlyStat {
  id                String   @id @default(uuid()) @db.Uuid
  stationId         String   @map("station_id") @db.VarChar(150)
  stationName       String   @map("station_name") @db.VarChar(255)
  hour              DateTime @db.Timestamptz(6)
  sessionsStarted   Int      @default(0) @map("sessions_started")
  sessionsCompleted Int      @default(0) @map("sessions_completed")
  sessionsFailed    Int      @default(0) @map("sessions_failed")
  activeSessions    Int      @default(0) @map("active_sessions")
  totalEnergyKwh    Decimal  @default(0) @map("total_energy_kwh") @db.Decimal(12, 3)
  totalRevenueLak   BigInt   @default(0) @map("total_revenue_lak")
  totalOverstayLak  BigInt   @default(0) @map("total_overstay_lak")
  overstayIncidents Int      @default(0) @map("overstay_incidents")
  notificationsSent Int      @default(0) @map("notifications_sent")

  @@unique([stationId, hour])
  @@index([hour(sort: Desc)])
  @@map("station_hourly_stats")
  @@schema("panda_ev_noti")
}

/// Pre-aggregated per-station session and revenue metrics, bucketed by calendar date
model StationDailyStat {
  id                     String   @id @default(uuid()) @db.Uuid
  stationId              String   @map("station_id") @db.VarChar(150)
  stationName            String   @map("station_name") @db.VarChar(255)
  date                   DateTime @db.Date
  totalSessions          Int      @default(0) @map("total_sessions")
  completedSessions      Int      @default(0) @map("completed_sessions")
  failedSessions         Int      @default(0) @map("failed_sessions")
  totalEnergyKwh         Decimal  @default(0) @map("total_energy_kwh") @db.Decimal(12, 3)
  totalRevenueLak        BigInt   @default(0) @map("total_revenue_lak")
  avgSessionMinutes      Decimal  @default(0) @map("avg_session_minutes") @db.Decimal(8, 2)
  peakConcurrentSessions Int      @default(0) @map("peak_concurrent_sessions")
  totalOverstayLak       BigInt   @default(0) @map("total_overstay_lak")
  overstayIncidents      Int      @default(0) @map("overstay_incidents")
  avgOverstayMinutes     Decimal  @default(0) @map("avg_overstay_minutes") @db.Decimal(8, 2)
  uniqueUsers            Int      @default(0) @map("unique_users")
  notificationsSent      Int      @default(0) @map("notifications_sent")
  notificationsFailed    Int      @default(0) @map("notifications_failed")

  @@unique([stationId, date])
  @@index([date(sort: Desc)])
  @@map("station_daily_stats")
  @@schema("panda_ev_noti")
}

// ============================================================
// SMS MODULE
// ============================================================

enum SmsNetworkType {
  ONNET
  OFFNET

  @@schema("panda_ev_noti")
}

enum SmsStatus {
  PENDING
  SENT
  DELIVERED
  FAILED

  @@schema("panda_ev_noti")
}

enum SmsType {
  OTP
  TEXT

  @@schema("panda_ev_noti")
}

/// One record per SMS submitted to the LTC API
model SmsLog {
  id              String         @id @default(uuid()) @db.Uuid
  transactionId   String         @unique @map("transaction_id") @db.VarChar(100)
  /// Country dialing code, e.g. "856" for Laos
  countryCode     String         @map("country_code") @db.VarChar(10)
  /// Local number without country code, e.g. "2078559999"
  mobileNumber    String         @map("mobile_number") @db.VarChar(20)
  /// First 3 digits of mobileNumber — identifies the carrier, e.g. "207" = Beeline
  operator        String         @db.VarChar(10)
  /// Full number as sent to LTC API, e.g. "8562078559999"
  fullPhoneNumber String         @map("full_phone_number") @db.VarChar(30)
  header          String         @db.VarChar(50)
  message         String         @db.Text
  smsType         SmsType        @map("sms_type")
  networkType     SmsNetworkType @map("network_type")
  /// 200 LAK (onnet) or 300 LAK (offnet)
  costLak         Int            @map("cost_lak")
  smid            String?        @db.VarChar(100)
  status          SmsStatus      @default(PENDING)
  resultCode      String?        @map("result_code") @db.VarChar(20)
  errorMessage    String?        @map("error_message") @db.Text
  /// Originating service: 'mobile', 'csms', 'api'
  sourceService   String         @map("source_service") @db.VarChar(50)
  userId          String?        @map("user_id") @db.VarChar(150)
  sessionId       String?        @map("session_id") @db.VarChar(150)
  sentAt          DateTime       @default(now()) @map("sent_at") @db.Timestamptz(6)
  deliveredAt     DateTime?      @map("delivered_at") @db.Timestamptz(6)

  @@index([fullPhoneNumber, sentAt])
  @@index([status, sentAt])
  @@index([networkType, sentAt])
  @@index([sourceService, sentAt])
  @@index([userId])
  @@map("sms_logs")
  @@schema("panda_ev_noti")
}

/// Pre-aggregated SMS delivery stats per calendar day.
/// Fields are auto-incremented via ON CONFLICT UPSERT on each SMS send — never recalculated.
model SmsDailyStat {
  id               String   @id @default(uuid()) @db.Uuid
  date             DateTime @db.Date
  onnetCount       Int      @default(0) @map("onnet_count")
  onnetAmountLak   BigInt   @default(0) @map("onnet_amount_lak")
  offnetCount      Int      @default(0) @map("offnet_count")
  offnetAmountLak  BigInt   @default(0) @map("offnet_amount_lak")
  totalCount       Int      @default(0) @map("total_count")
  totalAmountLak   BigInt   @default(0) @map("total_amount_lak")
  successCount     Int      @default(0) @map("success_count")
  failCount        Int      @default(0) @map("fail_count")
  otpCount         Int      @default(0) @map("otp_count")
  textCount        Int      @default(0) @map("text_count")
  uniqueRecipients Int      @default(0) @map("unique_recipients")

  @@unique([date])
  @@index([date(sort: Desc)])
  @@map("sms_daily_stats")
  @@schema("panda_ev_noti")
}

// ============================================================
// NOTIFICATION DAILY STATS (existing)
// ============================================================

/// Pre-aggregated notification delivery metrics per type+channel per day
model NotificationDailyStat {
  id              String              @id @default(uuid()) @db.Uuid
  date            DateTime            @db.Date
  type            String              @db.VarChar(100)
  channel         NotificationChannel
  totalSent       Int                 @default(0) @map("total_sent")
  totalDelivered  Int                 @default(0) @map("total_delivered")
  totalRead       Int                 @default(0) @map("total_read")
  totalClicked    Int                 @default(0) @map("total_clicked")
  totalFailed     Int                 @default(0) @map("total_failed")
  totalRetried    Int                 @default(0) @map("total_retried")
  totalSuppressed Int                 @default(0) @map("total_suppressed")

  @@unique([date, type, channel])
  @@index([date(sort: Desc)])
  @@map("notification_daily_stats")
  @@schema("panda_ev_noti")
}
